# Salesforce Playwright Framework Environment Variables

# Salesforce Environment
SALESFORCE_BASE_URL=https://your-domain.my.salesforce.com
SALESFORCE_LOGIN_URL=https://your-domain.my.salesforce.com
SALESFORCE_AUTH_URL=https://login.salesforce.com
SALESFORCE_INSTANCE_URL=https://your-domain.my.salesforce.com

# Salesforce Credentials
SALESFORCE_USERNAME=your-username@example.com
SALESFORCE_PASSWORD=your-password
SALESFORCE_ACCESS_TOKEN=
SALESFORCE_MFA_CODE=
SALESFORCE_TOTP_SECRET=
SALESFORCE_TOTP_URI=
SALESFORCE_TOTP_DIGITS=6
SALESFORCE_TOTP_PERIOD=30
SALESFORCE_TOTP_ALGORITHM=SHA1
SALESFORCE_MFA_TIMEOUT_MS=120000

# Salesforce API (OAuth Password Flow)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_API_VERSION=62.0

# Playwright Settings
PW_WORKERS=1
PW_RETRIES=0
PW_HEADLESS=1
PW_ENABLE_FIREFOX=0
PW_DEBUG_LIGHTNING_READY=0
PW_DEBUG_LIGHTNING_READY_STAGE=

# Auto-Heal (enable self-healing: 1/true/yes)
AUTO_HEAL=0
